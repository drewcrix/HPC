   "source": [
    "R = 1\n",
    "N = 100000\n",
    "M=1\n",
    "\n",
    "x = np.random.uniform(-R, R, N)\n",
    "y = np.random.uniform(-R, R, N)\n",
    "z = np.random.uniform(-R, R, N)\n",
    "\n",
    "sphere_condition = x**2 + y**2 + z**2  # this is r^2\n",
    "\n",
    "x_list = []\n",
    "y_list = []\n",
    "z_list = []\n",
    "\n",
    "for i in range(len(sphere_condition)):\n",
    "    if sphere_condition[i] <= R:   # compare to R^2\n",
    "        x_list.append(x[i])\n",
    "        y_list.append(y[i])\n",
    "        z_list.append(z[i])\n",
    "\n",
    "# convert to numpy arrays (optional, but convenient)\n",
    "x1 = np.array(x_list, dtype=float)\n",
    "y1 = np.array(y_list, dtype=float)\n",
    "z1 = np.array(z_list, dtype=float)\n",
    "\n",
    "Ixx = M*(np.mean(y1**2) + np.mean(z1**2))\n",
    "Iyy = M*(np.mean(x1**2) + np.mean(z1**2))\n",
    "Izz = M*(np.mean(x1**2) + np.mean(y1**2))\n",
    "Ixy = -M*np.mean(x1)*np.mean(y1)\n",
    "Ixz = -M*np.mean(x1)*np.mean(z1)\n",
    "Iyz = -M*np.mean(y1)*np.mean(z1)\n",
    "\n",
    "print(Ixx,Iyy,Izz,Ixy,Ixz,Iyz)\n",
    "\n",
    "fig = plt.figure()\n",
    "ax = fig.add_subplot(projection='3d')\n",
    "\n",
    "\n",
    "ax.scatter(x, y, z, s=5, alpha=0.02, label=\"Cube samples\")\n",
    "ax.scatter(x1, y1, z1, s=8, alpha=1, label=\"Inside sphere\")\n",
    "\n",
    "ax.legend()\n",
    "plt.show()\n",
    "\n"
   ]
