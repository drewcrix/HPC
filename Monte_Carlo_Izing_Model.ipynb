   ],
   "source": [
    "\n",
    "#initialize  \n",
    "alpha = 1 #initialize coupling constant\n",
    "m = [] #initialize magnetization list\n",
    "E = [] #initialize energy list\n",
    "time_steps = 10000 #initial time steps\n",
    "T = 0.5 #initialize temperature\n",
    "N = 100 #initialize number of spins\n",
    "t = np.arange(0, time_steps) #used for plotting\n",
    "\n",
    "\n",
    "#generate a list of, N, random spins \n",
    "spins = []\n",
    "for i in range(N):\n",
    "    spins.append(random.choice([-1,1])) #initializes spins randomly as either -1 or 1\n",
    "\n",
    "spins = np.array(spins) #array of random spins\n",
    "\n",
    "\n",
    "\n",
    "H1 = alpha * np.sum(spins[:-1] * spins[1:]) #total energy with these spin states! Total energy with this spin state\n",
    "\n",
    "\n",
    "def boundaryConditions(spins, ind):\n",
    "    if ind == N-1: #open boundary conditions at the end\n",
    "        spin = spins[ind]*spins[ind-1]\n",
    "        spin_flipped = spin*-1\n",
    "    elif ind == 0: #open boundary conditions at the beginning\n",
    "        spin = spins[ind]*spins[ind+1]\n",
    "        spin_flipped = spin*-1\n",
    "    else: #these spin combos are what is currently contributing to the energy. I need to replace these with the flipped state combos to see how the energy changes if I flip the spin at ind.\n",
    "        spin_comb = spins[ind]*spins[ind+1]\n",
    "        spin_comb2 = spins[ind]*spins[ind-1]\n",
    "\n",
    "        spin_comb_flipped = -1*spins[ind]*spins[ind+1]\n",
    "        spin_comb2_flipped = -1*spins[ind]*spins[ind-1]\n",
    "\n",
    "        spin = spin_comb + spin_comb2 \n",
    "\n",
    "        #this the flipped state term that I must replace with the term above\n",
    "        spin_flipped = spin_comb_flipped + spin_comb2_flipped \n",
    "    \n",
    "    return spin, spin_flipped\n",
    "\n",
    "\"\"\"\n",
    "def boundaryConditions_periodic(spins, ind):\n",
    "   \n",
    "    #Periodic boundary conditions for a 1D spin chain.\n",
    "\n",
    "    #Returns:\n",
    "      #spin:          contribution from bonds touching site ind (left + right)\n",
    "      #spin_flipped:  same contribution if spin at ind were flipped\n",
    "    \n",
    "    N = len(spins)\n",
    "\n",
    "    left  = (ind - 1) % N\n",
    "    right = (ind + 1) % N\n",
    "\n",
    "    # current local bond sum\n",
    "    spin = spins[ind] * spins[left] + spins[ind] * spins[right]\n",
    "\n",
    "    # flipping spins[ind] multiplies both bond terms by -1\n",
    "    spin_flipped = -spin\n",
    "\n",
    "    return spin, spin_flipped\n",
    "\"\"\"\n",
    "\n",
    "#now I want to see if changing a spin state will increase or decrease the energy and by how much \n",
    "for i in range(time_steps): #should this go through every possible state and check what happens to the energy if the state is flipped? What is the purpose of this? \n",
    "    ind = random.randint(0,N-1) #randomly select a spin to flip. Randomly sampling the possible states of the system. I am not going through every possible state, that would be brute force. Instead, I am randomly sampling the states and using the metropolis criterion to decide if I keep those states or not.\n",
    "    spin_state = spins[ind] #the current state of the spin at index ind. I want to flip this state and see how it affects the energy.\n",
    "\n",
    "    spin_old, spin_new = boundaryConditions(spins, ind) #these are the contributions to the energy from the current spin state and the flipped spin state. I need to replace the old contribution with the new contribution to see how the energy changes if I flip the spin at ind.\n",
    "\n",
    "    #replacing the old spin states with the new spin states\n",
    "    H2 = H1 - spin_old + spin_new\n",
    "\n",
    "    #calculating the change in total energy from the flipped states\n",
    "    deltaE = H2-H1 \n",
    "\n",
    "    \n",
    "    \n",
    "    Pm = min(1, (np.e)**-((deltaE)/T)) #metropolis criterion, did these flip states decrease the energy? If they did, then I will keep them. If they increased the energy, then I will keep them with a probability that depends on how much they increased the energy and the temperature of the system. The higher the temperature, the more likely I am to keep states that increase the energy. This is because at higher temperatures, the system has more thermal energy to overcome energy barriers and explore a wider range of states. At lower temperatures, the system is more likely to get stuck in local minima and only explore states that decrease the energy.\n",
    "\n",
    "    #keeping the flipped states that meet the metropolis criterion\n",
    "    x = np.random.rand() #generate a random number between 0 and 1. Important Aspect of Monte Carlo\n",
    "    #This here is the MONTE CARLO ASPECT!\n",
    "    if x <= Pm: #if a random number between 0 and 1 is less than or equal to the probability of keeping the flipped states, then I will keep the flipped states. This is how I am randomly sampling the states of the system and using the metropolis criterion to decide which states to keep.\n",
    "        spins[ind] = -1*spins[ind]\n",
    "        m.append(np.sum(spins)/N)\n",
    "        H1 = H2 #replace the old energy state with the new energy state then I keep going until I reach equillibrium \n",
    "        E.append(H1)\n",
    "    else:\n",
    "        m.append(np.sum(spins)/N)\n",
    "        E.append(H1)\n",
    "\n",
    "\n",
    "plt.plot(t, m) #time vs magnetization \n",
    "plt.xlabel(\"Algorithmic Time Steps\")\n",
    "plt.ylabel(\"Average Magnetization\")\n",
    "plt.show()\n",
    "\n",
    "plt.plot(t,E) #time vs energy. Energy will tend to decrease over time. Unless temperature is really high which will promote many switches.\n",
    "plt.xlabel(\"Algorithmic Time Steps\")\n",
    "plt.ylabel(\"Total Energy\")\n",
    "plt.show()\n",
    "\n",
    "    \n",
    "\n",
    "\n",
    "\n"
   ]
