    "R = 1\n",
    "N = 10000\n",
    "M=1\n",
    "H=9\n",
    "\n",
    "x = np.random.uniform(-R, R, N)\n",
    "y = np.random.uniform(-R, R, N)\n",
    "z = np.random.uniform(-H/2, H/2, N)\n",
    "\n",
    "cylinder_condition = (x**2 + y**2) <= R**2  \n",
    "\n",
    "x1,y1,z1 = x[cylinder_condition], y[cylinder_condition], z[cylinder_condition]\n",
    "\n",
    "Ixx = M*(np.mean(y1**2) + np.mean(z1**2))\n",
    "Iyy = M*(np.mean(x1**2) + np.mean(z1**2))\n",
    "Izz = M*(np.mean(x1**2) + np.mean(y1**2))\n",
    "Ixy = -M*np.mean(x1)*np.mean(y1)\n",
    "Ixz = -M*np.mean(x1)*np.mean(z1)\n",
    "Iyz = -M*np.mean(y1)*np.mean(z1)\n",
    "\n",
    "print(Ixx,Iyy,Izz,Ixy,Ixz,Iyz)\n",
    "\n",
    "fig = plt.figure()\n",
    "ax = fig.add_subplot(projection='3d')\n",
    "\n",
    "ax.scatter(x, y, z, s=5, alpha=0.05, label=\"Cube samples\")\n",
    "ax.scatter(x1, y1, z1, s=8, alpha=1, label=\"Inside sphere\")\n",
    "\n",
    "ax.legend()\n",
    "plt.show()\n",
    "\n"
   ]
