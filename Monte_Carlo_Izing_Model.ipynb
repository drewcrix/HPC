   "source": [
    "2. Investigating the Ising model for magnets.
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5f22c774",
   "metadata": {
    "vscode": {
     "languageId": "python"
    }
   },
   "outputs": [
    {
     "data": {
      "image/png": "",
